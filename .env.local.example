# Copy this to .env.local and fill in your Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin emails (comma-separated) — these users get access to /[locale]/admin
ADMIN_EMAILS=admin@yourdomain.com

# Optional: Google AdSense publisher ID (leave blank to show placeholder in dev)
NEXT_PUBLIC_ADSENSE_ID=
