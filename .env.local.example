# Copy this to .env.local and fill in your Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin emails (comma-separated) — these users get access to /[locale]/admin
ADMIN_EMAILS=admin@yourdomain.com

# Optional: Google AdSense publisher ID (leave blank to show placeholder in dev)
NEXT_PUBLIC_ADSENSE_ID=

# Optional: Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Email (payment notifications + expiry reminders — server only)
RESEND_API_KEY=
FROM_EMAIL=noreply@theorylane.app

# Optional: KBZPay / WavePay display (payment page)
NEXT_PUBLIC_KBZPAY_NUMBER=
NEXT_PUBLIC_WAVEPAY_NUMBER=
NEXT_PUBLIC_KBZPAY_NAME=
NEXT_PUBLIC_WAVEPAY_NAME=

# Public site URL (used for share links and SEO)
NEXT_PUBLIC_SITE_URL=https://theorylane.app
